{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NODE16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "types": ["node", "@playwright/test"]
  },
"include": [
  "tests/**/*.ts",
  "pages/**/*.ts",
  "fixtures/**/*.ts"
]
}